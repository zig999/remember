# BFF base URL — required; validated at boot (front.back.md BR-02)
VITE_BFF_URL=http://localhost:3000

# Neon Auth URL — required for JWT JWKS validation redirect (front.back.md §2)
VITE_NEON_AUTH_URL=https://<your-neon-auth-project>.neon.tech

# Stack Auth (Neon Auth) — D2 = Option A (SDK client-side, TC-03).
# The publishable client key is public by design — never log/treat as a secret.
VITE_STACK_PROJECT_ID=your-stack-project-id
VITE_STACK_PUBLISHABLE_CLIENT_KEY=your-publishable-client-key
