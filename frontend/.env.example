# BFF base URL — required; validated at boot (front.back.md BR-02)
VITE_BFF_URL=http://localhost:3000

# Neon Auth URL — required; Better Auth native provider base URL.
# features/auth/api/neon-auth.ts (TC-01) calls Better Auth's
# POST /sign-in/email + GET /token directly via raw fetch.
VITE_NEON_AUTH_URL=https://<your-neon-auth-project>.neon.tech
