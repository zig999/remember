{
  // Projeto isolado para o submodule read-only do UI-Kit (TUI).
  // O kit foi escrito sob flags menos estritas que o eternal; aqui o compilamos
  // como um projeto REFERENCIADO (composite) que emite apenas .d.ts. O projeto
  // principal (tsconfig.json) referencia este e passa a consumir as declarações
  // geradas — em vez de re-checar o source do kit sob as flags estritas do
  // eternal (exactOptionalPropertyTypes, noUncheckedIndexedAccess, etc.).
  // Nunca editar vendor/: divergências de tipo ficam contidas aqui.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./node_modules/.cache/ui-kit-types",
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitReturns": false,
    "noImplicitOverride": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "vendor/ui-kit/frontend/src/shared/**/*.ts",
    "vendor/ui-kit/frontend/src/shared/**/*.tsx"
  ],
  "exclude": ["vendor/ui-kit/frontend/src/shared/**/*.stories.tsx"]
}
