# --- Backend (BFF) environment variables ---
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# HTTP server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CORS — browser origins allowed to call the BFF. The SPA (Vite) runs on a
# different origin than the BFF, so it must be listed here or the browser blocks
# every cross-origin request. Comma-separated; matched exactly. Default (when
# unset) covers the Vite dev server on localhost and 127.0.0.1 (:5173).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (Neon — managed Postgres; use the direct, non-pooled connection string)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Optional pool tuning (defaults to min=2, max=10, statement_timeout=10s)
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=10000

# Neon Auth (Stack Auth) — JWT access tokens verified via JWKS
# NEON_AUTH_URL: the Neon Auth base URL, e.g. https://<endpoint>.neon.tech/<db>/auth
#   The BFF derives the JWKS endpoint as <NEON_AUTH_URL>/.well-known/jwks.json
NEON_AUTH_URL=

# Optional: JWKS cache lifetime (default 600 s = 10 min)
NEON_AUTH_JWKS_TTL_S=600

# DEV-ONLY: local operator token. When set AND NODE_ENV=development, a request
# with `Authorization: Bearer <this value>` is accepted as the owner without
# JWKS verification — the convenience path for local MCP clients (e.g. Claude
# Desktop via mcp-remote) that cannot run the Neon Auth OAuth flow. Min 16 chars.
# Leave blank to disable. Generate one with e.g. `openssl rand -hex 24`.
# FAIL-CLOSED: the BFF refuses to start if this is set while NODE_ENV is not
# explicitly `development` — so it can never silently enable a bypass in prod.
LOCAL_OPERATOR_TOKEN=

# Anthropic SDK (BR-29) — the orchestrator (BR-26) is the sole LLM caller of
# the BFF. Required; the BFF refuses to start without it. The value never
# appears in logs, responses, or stack traces.
ANTHROPIC_API_KEY=

# Chat — async ingestion capability (chat.back.md v2.4, BR-44). When `true`,
# the chat agentic loop also exposes `start_async_ingestion` (write — fires the
# validated ingestion pipeline as a background job) and `get_ingestion_status`
# (read), for 15 tools total; when `false` the chat stays the 13 read-only
# tools. Boot-time only — toggling requires a BFF restart (the catalog is
# resolved once and cached). Default `false`.
CHAT_INGEST_ENABLED=false
