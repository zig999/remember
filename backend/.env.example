# --- Backend (BFF) environment variables ---
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# HTTP server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL (Supabase Cloud — direct connection string)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Optional pool tuning (defaults to min=2, max=10, statement_timeout=10s)
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=10000

# Supabase Auth — JWKS endpoint and project URL
# SUPABASE_URL: e.g. https://<ref>.supabase.co
# SUPABASE_SERVICE_KEY: ONLY used by the BFF. Never exposed to the SPA.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional: JWKS cache lifetime (default 600 s = 10 min)
SUPABASE_JWKS_TTL_S=600
