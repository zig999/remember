# --- Backend (BFF) environment variables ---
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# HTTP server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL (Neon — managed Postgres; use the direct, non-pooled connection string)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Optional pool tuning (defaults to min=2, max=10, statement_timeout=10s)
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=10000

# Neon Auth (Stack Auth) — JWT access tokens verified via JWKS
# NEON_AUTH_URL: the Neon Auth base URL, e.g. https://<endpoint>.neon.tech/<db>/auth
#   The BFF derives the JWKS endpoint as <NEON_AUTH_URL>/.well-known/jwks.json
NEON_AUTH_URL=

# Optional: JWKS cache lifetime (default 600 s = 10 min)
NEON_AUTH_JWKS_TTL_S=600
