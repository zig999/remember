# --- Orchestration engine runtime state — never commit (CLAUDE.md) ---
.orch/
.claude/scheduled_tasks.lock

# --- Python bytecode (compiled framework scripts) ---
__pycache__/
*.pyc

# --- Scratch / working notes (not source) ---
/temp/
/scratchpad/

# --- Node ---
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
.vite/
*.log
npm-debug.log*

# --- Environment / secrets (keep .env.example) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets.*
credentials.*
credentials.md

# --- WSL / Windows artifacts ---
*Zone.Identifier
.DS_Store
Thumbs.db
